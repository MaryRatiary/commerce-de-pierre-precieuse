{
  "version": "1.0",
  "policies": {
    "secret_scanning": {
      "enabled": true,
      "tools": ["gitleaks", "github-native"],
      "patterns": [
        "api_key",
        "aws_access_key",
        "private_key",
        "database_password",
        "jwt_secret",
        "oauth_token"
      ],
      "action": "block_commit",
      "severity": "critical"
    },
    "sast": {
      "enabled": true,
      "tools": ["semgrep", "github-codeql"],
      "rules": [
        "p/owasp-top-ten",
        "p/cwe-top-25",
        "p/security-audit",
        "p/javascript",
        "p/csharp"
      ],
      "fail_on_severity": "high",
      "action": "block_pr"
    },
    "dependency_scanning": {
      "enabled": true,
      "tools": ["dependabot", "npm-audit", "dotnet-list-vulnerable"],
      "update_strategy": "automatic",
      "auto_merge": {
        "patch": true,
        "minor": false,
        "major": false
      },
      "fail_on_severity": "critical"
    },
    "container_scanning": {
      "enabled": true,
      "tools": ["trivy", "github-container-scanning"],
      "fail_on_severity": "high",
      "base_image_policy": {
        "allowed_registries": ["docker.io", "ghcr.io"],
        "require_digest": true,
        "max_age_days": 30
      }
    },
    "sbom_generation": {
      "enabled": true,
      "tools": ["syft"],
      "formats": ["json", "cyclonedx"],
      "store_in_repo": true,
      "upload_to_github": true
    },
    "code_quality": {
      "enabled": true,
      "tools": ["sonarqube", "eslint", "dotnet-format"],
      "coverage_threshold": 0.80,
      "duplication_threshold": 0.05,
      "fail_on_violations": true
    },
    "access_control": {
      "branch_protection": {
        "main": {
          "require_pr_reviews": 2,
          "require_status_checks": true,
          "require_updated_branch": true,
          "allow_force_pushes": false,
          "allow_deletions": false
        },
        "develop": {
          "require_pr_reviews": 1,
          "require_status_checks": true,
          "allow_force_pushes": false
        }
      },
      "secret_rotation": {
        "enabled": true,
        "rotation_days": 90,
        "alert_days": 30
      }
    },
    "artifact_security": {
      "signing": {
        "enabled": true,
        "algorithm": "cosign",
        "key_storage": "github-secrets"
      },
      "registry": {
        "type": "ghcr",
        "private": true,
        "immutable": true,
        "retention_days": 90
      },
      "vulnerability_scan": {
        "before_push": true,
        "before_deploy": true,
        "max_retries": 3
      }
    },
    "logging_audit": {
      "enabled": true,
      "log_level": "info",
      "mask_secrets": true,
      "retention_days": 180,
      "export_to": ["github-logs", "cloudwatch"]
    }
  },
  "compliance": {
    "frameworks": ["owasp-top-10", "cwe-top-25", "nist-800-218"],
    "audit_frequency": "monthly",
    "penetration_testing": "quarterly"
  },
  "incident_response": {
    "secret_exposed": {
      "action": "immediate_rotation",
      "notify": ["security-team", "slack"],
      "audit_lookback_days": 90
    },
    "vulnerability_critical": {
      "action": "block_deployment",
      "escalation": "p1",
      "sla_hours": 4
    }
  }
}
